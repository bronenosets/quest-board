# Copy to .env.local and fill in. Find these values in:
# Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# The service role key. Used ONLY in server actions for admin operations
# (e.g. resolving a user_id from email when sending an invite). NEVER expose
# this in client code. Vercel: add it as a regular Environment Variable.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Where the app is deployed. Used for magic-link redirect URLs.
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Web push (VAPID). Generate ONCE with:
#   npx web-push generate-vapid-keys
# Then put the public key here, the private below, and your contact email
# (used by browser push services to reach you if there's a problem).
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:nikita@logotech.com

# Optional: protects /api/cron/* endpoints from public hits. Vercel Cron
# attaches Authorization: Bearer $CRON_SECRET. Generate any random string.
CRON_SECRET=
